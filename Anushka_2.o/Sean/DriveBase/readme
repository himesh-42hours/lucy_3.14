OUTLINE: 
# Init methods

# Check for values coming from other modules

comm= driveBaseWS.readline()

    if len(comm) == 0:
        continue

    if comm == "-1":
        break

    # print(comm)
    if "left" in comm:
        if comm == "@left":
            didMove= move(leftcommand, 1)
        else:
            didMove= move(leftcommand, 5)

    elif "right" in comm:
        if comm == "@right":
            didMove= move(rightcommand, 1)
        else:
            didMove= move(rightcommand, 5)

    elif "forward" in comm or "ahead" in comm:
        step= extractStep(comm)
        print(step)
        didMove= move(forcommand, step)

    elif ListCheck(["back", "behind", "reverse"], comm):
        step= extractStep(comm)
        didMove= move(backcommand, step)
